{
  "name": "@hwcharlton/geo-model",
  "version": "0.1.0",
  "description": "Deps-free shared model for the @hwcharlton geo-data ecosystem: layer taxonomy + OSM→layer mapping, EPSG:6677 (JGD2011 Japan Plane Rectangular CS IX) projection, and license/provenance/manifest types.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "format": "prettier . --write",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm run build"
  },
  "author": "Henry Charlton",
  "license": "ISC",
  "devDependencies": {
    "@hwcharlton/git-hooks": "^0.0.1",
    "@types/node": "^20.11.16",
    "@types/proj4": "^2.5.6",
    "prettier": "^3.2.5",
    "proj4": "^2.19.10",
    "rimraf": "^5.0.5",
    "simple-git-hooks": "^2.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9",
    "typescript-eslint": "^8.5.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^4.5.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx hwc-git-hooks pre-commit"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks"
    ]
  }
}
